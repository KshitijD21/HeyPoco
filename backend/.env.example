# App
APP_NAME=HeyPoco API
DEBUG=true
CORS_ORIGINS=["http://localhost:3333","http://localhost:3000"]

# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Database (for running migrations via psql)
# Find in: Supabase Dashboard → Settings → Database → Connection string → URI
DATABASE_URL=postgresql://postgres:[password]@db.[project-ref].supabase.co:5432/postgres

# OpenAI
OPENAI_API_KEY=sk-your-openai-key
OPENAI_MODEL=gpt-4o
OPENAI_WHISPER_MODEL=whisper-1
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# Waitlist / access request notifications
RESEND_API_KEY=re_xxxxxxxx
WAITLIST_NOTIFY_EMAIL=you@example.com

# Dev / testing (only used when DEBUG=true)
# Set this to your Supabase user UUID — see supabase/seed.sql for setup steps
TEST_USER_ID=your-supabase-user-uuid
